#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.11"
# dependencies = []
# ///

"""
Wrapper around `age` for encrypting/decrypting secrets using pre-configured keys.

Identity resolution order:
  1. AGE_IDENTITY_FILE env var
  2. SEED_INSTANCE_NAME env var → /seed_config/.age/key
  3. ~/.age/key.txt
"""

import argparse
import os
import subprocess
import sys
from pathlib import Path


REPO_ROOT = Path(__file__).resolve().parent.parent


def resolve_identity() -> Path:
    if id_file := os.environ.get("AGE_IDENTITY_FILE"):
        p = Path(id_file)
        if not p.exists():
            sys.exit(f"error: AGE_IDENTITY_FILE={id_file} does not exist")
        return p

    if os.environ.get("SEED_INSTANCE_NAME"):
        p = Path("/seed_config/.age/key")
        if p.exists():
            return p

    fallback = Path.home() / ".age" / "key.txt"
    if fallback.exists():
        return fallback

    sys.exit(
        "error: no age identity found — set AGE_IDENTITY_FILE, or SEED_INSTANCE_NAME "
        "(with /seed_config/.age/key), or place a key at ~/.age/key.txt"
    )


def pubkeys_for_instance(instance: str) -> list[str]:
    instance_dir = REPO_ROOT / instance
    if not instance_dir.is_dir():
        sys.exit(f"error: instance directory '{instance_dir}' does not exist")

    apub_files = sorted(instance_dir.glob("*.apub"))
    if not apub_files:
        sys.exit(f"error: no *.apub files found in '{instance_dir}'")

    keys = []
    for f in apub_files:
        content = f.read_text().strip()
        for line in content.splitlines():
            line = line.strip()
            if line and not line.startswith("#"):
                keys.append(line)

    if not keys:
        sys.exit(f"error: no public keys found in *.apub files under '{instance_dir}'")

    return keys


def identity_pubkey(identity: Path) -> str | None:
    """Extract the public key from an age identity file (comment line starting with '# public key:')."""
    try:
        for line in identity.read_text().splitlines():
            line = line.strip()
            if line.lower().startswith("# public key:"):
                return line.split(":", 1)[1].strip()
    except OSError:
        pass
    return None


def cmd_encrypt(args: argparse.Namespace) -> None:
    identity = resolve_identity()
    recipients = pubkeys_for_instance(args.to)

    own_pubkey = identity_pubkey(identity)
    if own_pubkey and own_pubkey not in recipients:
        recipients.append(own_pubkey)

    age_cmd = ["age", "--encrypt"]
    for key in recipients:
        age_cmd += ["--recipient", key]

    if args.output:
        age_cmd += ["--output", args.output]

    if args.input:
        age_cmd += [args.input]

    stdin_data = None
    if not args.input:
        stdin_data = sys.stdin.buffer.read()

    result = subprocess.run(
        age_cmd,
        input=stdin_data,
        capture_output=(not args.input and not args.output),
    )

    if result.returncode != 0:
        sys.exit(result.returncode)

    if not args.output and result.stdout:
        sys.stdout.buffer.write(result.stdout)


def cmd_decrypt(args: argparse.Namespace) -> None:
    identity = resolve_identity()

    age_cmd = ["age", "--decrypt", "--identity", str(identity)]

    if args.output:
        age_cmd += ["--output", args.output]

    if args.input:
        age_cmd += [args.input]

    stdin_data = None
    if not args.input:
        stdin_data = sys.stdin.buffer.read()

    result = subprocess.run(
        age_cmd,
        input=stdin_data,
        capture_output=(not args.input and not args.output),
    )

    if result.returncode != 0:
        sys.exit(result.returncode)

    if not args.output and result.stdout:
        sys.stdout.buffer.write(result.stdout)


def main() -> None:
    parser = argparse.ArgumentParser(
        prog="secrets",
        description="Encrypt/decrypt secrets using age and pre-configured keys.",
    )
    sub = parser.add_subparsers(dest="command", required=True)

    enc = sub.add_parser("encrypt", help="Encrypt a secret for a named instance")
    enc.add_argument("--to", required=True, metavar="INSTANCE", help="Target instance (folder with *.apub files)")
    enc.add_argument("-i", dest="input", metavar="FILE", default=None, help="Input file (default: stdin)")
    enc.add_argument("-o", dest="output", metavar="FILE", default=None, help="Output file (default: stdout)")

    dec = sub.add_parser("decrypt", help="Decrypt a secret using the local identity")
    dec.add_argument("-i", dest="input", metavar="FILE", default=None, help="Input file (default: stdin)")
    dec.add_argument("-o", dest="output", metavar="FILE", default=None, help="Output file (default: stdout)")

    args = parser.parse_args()

    if args.command == "encrypt":
        cmd_encrypt(args)
    elif args.command == "decrypt":
        cmd_decrypt(args)


if __name__ == "__main__":
    main()
